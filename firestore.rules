rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Пользователи (users)
    // ============================================
    // - Чтение/листинг: все авторизованные
    // - Запись: только владелец документа
    match /users/{userId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // Подписки (subscriptions)
    // ============================================
    // Авторизованные могут управлять своими подписками
    match /subscriptions/{subscriptionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ============================================
    // Сообщения (messages)
    // ============================================
    // Участники чата могут читать и писать
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // Чаты (chats)
    // ============================================
    // Участники чата могут читать и писать
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // Общий контент (sharedContent)
    // ============================================
    // Все авторизованные могут читать и писать
    match /sharedContent/{contentId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // Уведомления (notifications)
    // ============================================
    // Пользователи могут читать и писать свои уведомления
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }
  }
}
