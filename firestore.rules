rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Коллекция users - все авторизованные могут читать ВСЕХ пользователей
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Разрешаем листинг для всех авторизованных
      allow list: if request.auth != null;
    }

    // Коллекция messages - участники чата могут читать/писать
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Коллекция chats - участники чата могут читать/писать
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }

    // Коллекция sharedContent - все авторизованные могут читать/писать
    match /sharedContent/{contentId} {
      allow read, write: if request.auth != null;
    }

    // Коллекция notifications - пользователи могут читать/писать свои уведомления
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }
  }
}
